<Window x:Class="XbaTool.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XBA Archive Tool — Help"
        Width="860" Height="600"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrBg}"
        WindowStyle="ToolWindow"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="140" MaxWidth="280"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Topic tree ──────────────────────────────────────────────── -->
        <Border Grid.Column="0" Background="{StaticResource BrBg2}">
            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource BrBg3}"
                        Padding="12,8">
                    <TextBlock Text="Topics"
                               Foreground="{StaticResource BrFgDim}"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                </Border>

                <ListBox x:Name="TopicList"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0,4"
                         SelectionChanged="TopicList_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Foreground"  Value="{StaticResource BrFg}"/>
                            <Setter Property="FontFamily"  Value="Segoe UI"/>
                            <Setter Property="FontSize"    Value="13"/>
                            <Setter Property="Padding"     Value="14,7"/>
                            <Setter Property="Cursor"      Value="Hand"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="Transparent"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{StaticResource BrBg3}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{StaticResource BrAccent}"/>
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource BrFg}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBoxItem Content="Getting Started"/>
                    <ListBoxItem Content="The Toolbar"/>
                    <ListBoxItem Content="The File List"/>
                    <ListBoxItem Content="Pack"/>
                    <ListBoxItem Content="Unpack"/>
                    <ListBoxItem Content="Test"/>
                    <ListBoxItem Content="Format: V1"/>
                    <ListBoxItem Content="Format: V2"/>
                    <ListBoxItem Content="Format: V3"/>
                    <ListBoxItem Content="Errors &amp; Fixes"/>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ── Splitter ────────────────────────────────────────────────── -->
        <GridSplitter Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource BrBg3}"/>

        <!-- ── Content pane ────────────────────────────────────────────── -->
        <DockPanel Grid.Column="2">
            <!-- Title bar -->
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource BrBg2}"
                    Padding="24,12">
                <TextBlock x:Name="TxtTopicTitle"
                           Foreground="{StaticResource BrFg}"
                           FontFamily="Segoe UI"
                           FontSize="18"
                           FontWeight="SemiBold"/>
            </Border>

            <!-- Body -->
            <ScrollViewer Padding="24,16"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ContentPanel"/>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Window>
