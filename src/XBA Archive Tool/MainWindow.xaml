<Window x:Class="XbaTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:XbaTool"
        Title="XBA Archive Tool"
        Width="1080" Height="640"
        MinWidth="720" MinHeight="440"
        Background="{StaticResource BrBg}"
        WindowStyle="SingleBorderWindow"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             Toolbar
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource BrBg3}" Padding="2">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource ToolBtn}"
                        Content="📂  Open"   Click="BtnOpen_Click"   Margin="1"/>
                <Button Style="{StaticResource ToolBtn}"
                        Content="📦  Pack"   Click="BtnPack_Click"   Margin="1"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                    <RadioButton x:Name="RbV2" Content="V2" IsChecked="True"
                                 Foreground="{StaticResource BrFg}"
                                 VerticalAlignment="Center" Margin="2,0"/>
                    <RadioButton x:Name="RbV1" Content="V1"
                                 Foreground="{StaticResource BrFg}"
                                 VerticalAlignment="Center" Margin="2,0"/>
                </StackPanel>
                <Button Style="{StaticResource ToolBtn}"
                        Content="📤  Unpack" Click="BtnUnpack_Click" Margin="1"
                        x:Name="BtnUnpack" IsEnabled="False"/>
                <Button Style="{StaticResource ToolBtn}"
                        Content="✔   Test"  Click="BtnTest_Click"   Margin="1"
                        x:Name="BtnTest"   IsEnabled="False"/>
                <Separator Width="1" Background="{StaticResource BrBg2}"
                           Margin="4,4"/>
                <Button Style="{StaticResource ToolBtn}"
                        Content="ℹ   About" Click="BtnAbout_Click"  Margin="1"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             Path bar
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="{StaticResource BrBg2}" Padding="8,3">
            <TextBlock x:Name="TxtPath"
                       Text="No archive open  —  drag and drop an .xba file or use Open"
                       Foreground="{StaticResource BrFgDim}"
                       FontFamily="Segoe UI" FontSize="12"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             File list
             ═══════════════════════════════════════════════════════════════ -->
        <ListView x:Name="FileList"
                  Grid.Row="2"
                  Style="{StaticResource DarkListView}"
                  ItemContainerStyle="{StaticResource DarkListViewItem}"
                  SelectionMode="Extended"
                  MouseDoubleClick="FileList_DoubleClick"
                  SelectionChanged="FileList_SelectionChanged">
            <ListView.ContextMenu>
                <ContextMenu Background="{StaticResource BrBg3}"
                             Foreground="{StaticResource BrFg}"
                             BorderBrush="{StaticResource BrBg4}">
                    <MenuItem Header="Unpack…" Click="BtnUnpack_Click"
                              Foreground="{StaticResource BrFg}"/>
                    <MenuItem Header="Test"    Click="BtnTest_Click"
                              Foreground="{StaticResource BrFg}"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name"       Width="300"
                                    DisplayMemberBinding="{Binding Path}"/>
                    <GridViewColumn Header="Type"       Width="68"
                                    DisplayMemberBinding="{Binding TypeLabel}"/>
                    <GridViewColumn Header="Filter"     Width="55"
                                    DisplayMemberBinding="{Binding FilterLabel}"/>
                    <GridViewColumn Header="Blocks"     Width="52"
                                    DisplayMemberBinding="{Binding BlocksLabel}"/>
                    <GridViewColumn Header="Size"       Width="95"
                                    DisplayMemberBinding="{Binding SizeLabel}"/>
                    <GridViewColumn Header="Compressed" Width="100"
                                    DisplayMemberBinding="{Binding CompLabel}"/>
                    <GridViewColumn Header="Ratio"      Width="65"
                                    DisplayMemberBinding="{Binding RatioLabel}"/>
                    <GridViewColumn Header="CRC32"      Width="88"
                                    DisplayMemberBinding="{Binding CrcLabel}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- ═══════════════════════════════════════════════════════════════
             Progress bar
             ═══════════════════════════════════════════════════════════════ -->
        <ProgressBar x:Name="ProgressBar"
                     Grid.Row="3"
                     Style="{StaticResource DarkProgress}"
                     Minimum="0" Maximum="100" Value="0"
                     Visibility="Collapsed"/>

        <!-- ═══════════════════════════════════════════════════════════════
             Status bar
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="{StaticResource BrBg2}" Padding="6,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus"
                           Grid.Column="0"
                           Text="Ready"
                           Foreground="{StaticResource BrFgDim}"
                           FontFamily="Segoe UI" FontSize="12"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="TxtCount"
                           Grid.Column="1"
                           Text=""
                           Foreground="{StaticResource BrFgDim}"
                           FontFamily="Segoe UI" FontSize="12"
                           Margin="16,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
