<Window x:Class="XbaTool.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About XBA Archive Tool"
        Width="560"
        Height="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrBg}"
        WindowStyle="ToolWindow">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="XBA Archive Tool"
                   Foreground="{StaticResource BrFg}"
                   FontFamily="Segoe UI"
                   FontSize="26"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <!-- Subtitle -->
        <TextBlock Grid.Row="1"
                   Text="v1.0  ·  Custom XBA Archive Format"
                   Foreground="{StaticResource BrFgDim}"
                   FontFamily="Segoe UI"
                   FontSize="15"
                   HorizontalAlignment="Center"
                   Margin="0,6,0,0"/>

        <!-- Logos (main focus) -->
        <Grid Grid.Row="2" Margin="0,28,0,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- XBA -->
            <Image Grid.Column="0"
                   Source="pack://application:,,,/Assets/xba.png"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   MaxWidth="200"
                   MaxHeight="200"/>

            <!-- Darkone -->
            <Image Grid.Column="2"
                   Source="pack://application:,,,/Assets/darkone83.png"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   MaxWidth="320"
                   MaxHeight="160"/>
        </Grid>

        <!-- Branding -->
        <StackPanel Grid.Row="3"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center">
            <TextBlock Text="Darkone83  ×  Team Resurgent"
                       Foreground="{StaticResource BrAccentHot}"
                       FontFamily="Segoe UI"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Close button -->
        <Button Grid.Row="4"
                Content="Close"
                Style="{StaticResource ToolBtn}"
                HorizontalAlignment="Center"
                Margin="0,22,0,0"
                Padding="36,10"
                Click="CloseBtn_Click"/>
    </Grid>
</Window>